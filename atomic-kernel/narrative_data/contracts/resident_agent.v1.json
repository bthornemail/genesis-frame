{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "resident_agent.v1.json",
  "title": "Resident Agent Tick Output v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "authority",
    "seed",
    "chapter_id",
    "start_tick",
    "ticks",
    "residents",
    "action_enum",
    "proposals",
    "replay_hash"
  ],
  "properties": {
    "v": { "const": "resident_agent_tick.v1" },
    "authority": { "const": "advisory" },
    "seed": { "type": "string", "minLength": 1, "maxLength": 128 },
    "chapter_id": { "type": "string", "pattern": "^ch_[a-f0-9]+$" },
    "start_tick": { "type": "integer", "minimum": 0 },
    "ticks": { "type": "integer", "minimum": 1, "maximum": 128 },
    "residents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "goal"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "role": { "type": "string", "minLength": 1, "maxLength": 64 },
          "goal": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "action_enum": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "choice_select",
          "camera_branch",
          "avatar_swap",
          "scene_pace_change"
        ]
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposal_id",
          "status",
          "tick",
          "chapter_id",
          "actor_id",
          "action",
          "target",
          "requested_state"
        ],
        "properties": {
          "proposal_id": { "type": "string", "minLength": 8, "maxLength": 96 },
          "status": { "const": "pending" },
          "tick": { "type": "integer", "minimum": 0 },
          "chapter_id": { "type": "string", "pattern": "^ch_[a-f0-9]+$" },
          "actor_id": { "type": "string", "minLength": 1, "maxLength": 64 },
          "action": {
            "type": "string",
            "enum": [
              "choice_select",
              "camera_branch",
              "avatar_swap",
              "scene_pace_change"
            ]
          },
          "target": { "type": "string", "minLength": 1, "maxLength": 128 },
          "requested_state": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "replay_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
