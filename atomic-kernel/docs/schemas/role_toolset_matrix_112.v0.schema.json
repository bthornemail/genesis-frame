{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "role_toolset_matrix_112.v0.schema.json",
  "title": "Role Toolset Matrix 112 v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "authority",
    "basis",
    "control_plane_tools",
    "source_agent_matrix",
    "source_agent_matrix_replay_hash",
    "roles",
    "replay_hash"
  ],
  "properties": {
    "v": { "const": "role_toolset_matrix_112.v0" },
    "authority": { "const": "advisory" },
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "lanes_per_role", "proof_forms_per_lane", "formula", "algorithm_families"],
      "properties": {
        "roles": { "const": 8 },
        "lanes_per_role": { "const": 7 },
        "proof_forms_per_lane": { "const": 2 },
        "formula": { "const": "8x7x2" },
        "algorithm_families": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "control_plane_tools": { "$ref": "#/$defs/toolset" },
    "source_agent_matrix": { "type": "string", "minLength": 1 },
    "source_agent_matrix_replay_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "roles": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/role" }
    },
    "replay_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "availability"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "availability": { "type": "string", "enum": ["available", "planned"] }
      }
    },
    "toolset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "mcp_tools"],
      "properties": {
        "basis": { "type": "string", "minLength": 1 },
        "mcp_tools": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/tool" }
        }
      }
    },
    "assistant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assistant_id", "proof_form", "cell_id"],
      "properties": {
        "assistant_id": { "type": "string", "minLength": 1 },
        "proof_form": { "type": "string", "enum": ["constructive", "falsification"] },
        "cell_id": { "type": "string", "minLength": 1 }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_id", "agent_id", "algorithm_family", "proof_assistants", "toolset"],
      "properties": {
        "lane_id": { "type": "string", "minLength": 1 },
        "agent_id": { "type": "string", "minLength": 1 },
        "algorithm_family": { "type": "string", "minLength": 1 },
        "proof_assistants": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/assistant" }
        },
        "toolset": { "$ref": "#/$defs/toolset" }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_id", "question_id", "question_slug", "priority_band", "lane_agents"],
      "properties": {
        "role_id": { "type": "string", "minLength": 1 },
        "question_id": { "type": "string", "pattern": "^Q[1-8]$" },
        "question_slug": { "type": "string", "minLength": 1 },
        "priority_band": { "type": "string", "enum": ["critical", "important", "expansive"] },
        "lane_agents": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/lane" }
        }
      }
    }
  }
}
