{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical_time_policy.v0.schema.json",
  "title": "Canonical Time Policy v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "version",
    "authority",
    "canonical_time_source",
    "tick_advancement",
    "ordering_authority",
    "eligibility_function",
    "proposal_acceptance_boundary",
    "reject_conditions"
  ],
  "properties": {
    "type": { "const": "canonical_time_policy" },
    "version": { "const": 0 },
    "authority": { "const": "algorithmic" },
    "canonical_time_source": { "const": "algorithmic_tick" },
    "tick_advancement": { "const": "tick_next = tick_current + 1" },
    "ordering_authority": {
      "type": "string",
      "enum": ["chirality_within_tick_only"]
    },
    "eligibility_function": { "const": "eligible(action,state,canonical_tick)" },
    "proposal_acceptance_boundary": { "const": "lawful_tick_boundary" },
    "reject_conditions": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 8 }
    }
  }
}
