{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_provider_policy.v0.schema.json",
  "title": "Agent Provider Policy v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v",
    "authority",
    "profiles",
    "runtime_probe",
    "selected_profile",
    "selected_provider",
    "replay_hash"
  ],
  "properties": {
    "v": { "const": "agent_provider_policy.v0" },
    "authority": { "const": "advisory" },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["small", "medium", "large"],
      "properties": {
        "small": { "$ref": "#/$defs/profile" },
        "medium": { "$ref": "#/$defs/profile" },
        "large": { "$ref": "#/$defs/profile" }
      }
    },
    "runtime_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opencode", "ollama_binary", "ollama_server", "openclaw_adapter"],
      "properties": {
        "opencode": { "type": "boolean" },
        "ollama_binary": { "type": "boolean" },
        "ollama_server": { "type": "boolean" },
        "openclaw_adapter": { "type": "boolean" }
      }
    },
    "selected_profile": { "type": "string", "enum": ["small", "medium", "large"] },
    "selected_provider": { "type": "string", "enum": ["mock", "ollama", "opencode", "openclaw_adapter"] },
    "replay_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
  },
  "$defs": {
    "profile": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["mock", "ollama", "opencode", "openclaw_adapter"] },
      "uniqueItems": true
    }
  }
}
