{
  "name": "atomic-kernel",
  "version": "1.0.0",
  "private": true,
  "description": "Atomic Kernel deterministic transport/artifact tooling",
  "type": "module",
  "scripts": {
    "check:parity": "node js_runtime/check_parity.mjs",
    "immersive:parity:v1:gate": "bash tools/immersive_parity_v1_gate.sh",
    "resident:tick:v1": "python3 tools/resident_agent_tick_v1.py --seed resident-v1 --chapter-id ch_0185dd34c89e --start-tick 0 --ticks 8 --write",
    "resident:v1:gate": "bash tools/resident_agent_v1_gate.sh",
    "agent112:build:v0": "python3 tools/build_agent112_registry_v0.py --write",
    "agent112:verify:v0": "python3 tools/build_agent112_registry_v0.py --verify",
    "agent112:v0:gate": "bash tools/agent112_v0_gate.sh",
    "role-toolset:build:v0": "python3 tools/build_role_toolset_matrix_v0.py --write",
    "role-toolset:verify:v0": "python3 tools/build_role_toolset_matrix_v0.py --verify",
    "canonical-time:v0:gate": "bash tools/canonical_time_v0_gate.sh",
    "agent-action-proposal:build:v0": "python3 tools/agent_action_proposal_v0.py --provider mock --intent \"Queue chapter-scene dialogue branch proposal\" --write",
    "agent-action-proposal:verify:v0": "python3 tools/agent_action_proposal_v0.py --verify --intent \"verify-contract-shape\"",
    "agent-action-proposal:v0:gate": "bash tools/agent_action_proposal_v0_gate.sh",
    "agent-provider:bootstrap:v0": "bash tools/agent_provider_bootstrap_v0.sh small",
    "agent-provider:build:v0": "python3 tools/agent_provider_router_v0.py --profile ${AGENT_BANDWIDTH_PROFILE:-small} --write",
    "agent-provider:verify:v0": "python3 tools/agent_provider_router_v0.py --verify",
    "agent-provider:v0:gate": "bash tools/agent_provider_router_v0_gate.sh",
    "build:artifact-package-fixtures": "python3 tools/build_artifact_package_fixture.py --write && node tools/build_artifact_package_png_fixture.mjs --write",
    "verify:artifact-package-fixtures": "python3 tools/build_artifact_package_fixture.py --verify && node tools/build_artifact_package_png_fixture.mjs --verify",
    "build:wordnet": "python3 tools/build_wordnet_5wn_index.py --write",
    "verify:wordnet": "python3 tools/build_wordnet_5wn_index.py --verify",
    "build:imports-manifest": "python3 tools/build_import_asset_manifest.py --write",
    "verify:imports-manifest": "python3 tools/build_import_asset_manifest.py --verify",
    "build:nlp-bundle": "browserify nlp/wn_bridge.js -o nlp/bundle.js",
    "build:nlp": "npm run build:wordnet && npm run build:nlp-bundle"
  },
  "dependencies": {
    "@zxing/library": "0.21.3",
    "bwip-js": "4.7.0",
    "wink-eng-lite-web-model": "1.8.1",
    "wink-nlp": "2.4.0"
  },
  "devDependencies": {
    "browserify": "17.0.1"
  }
}
